# CrewCraft Agent Docker Image
#
# Build:
#   docker build -f Dockerfile.agent -t crewcraft-agent .
#
# The Gateway spawns containers from this image when
# CREWCRAFT_AGENT_DEPLOY_MODE=docker.

FROM python:3.13-slim

WORKDIR /app

# Install dependencies
RUN pip install --no-cache-dir \
    fastapi>=0.115.0 \
    uvicorn[standard]>=0.30.0 \
    typer>=0.12.0 \
    httpx>=0.27.0 \
    websockets>=12.0 \
    deepagents>=0.6.0 \
    python-dotenv>=1.0.0

# Copy application code
COPY app/ app/
COPY pyproject.toml .

ENV PYTHONPATH=/app
ENV CREWCRAFT_DATA_DIR=/data

# Agent will connect to host's gateway via host.docker.internal
# Override in docker-compose or docker run if needed

CMD ["python", "-m", "app.agent.server"]
