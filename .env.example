# CrewCraft Configuration
# Copy this file to .env and customize as needed.
# All values shown are defaults.

# ── Data ──────────────────────────────────────────────────────────
# CREWCRAFT_DATA_DIR=data

# ── Gateway REST API ──────────────────────────────────────────────
# CREWCRAFT_GATEWAY_HOST=127.0.0.1
# CREWCRAFT_GATEWAY_PORT=8000

# ── Gateway WebSocket (for agent connections) ─────────────────────
# CREWCRAFT_WS_HOST=127.0.0.1
# CREWCRAFT_WS_PORT=8765

# ── Agent ─────────────────────────────────────────────────────────
# CREWCRAFT_AGENT_DEPLOY_MODE=subprocess   # subprocess | docker
# CREWCRAFT_AGENT_PORT_START=9001
# CREWCRAFT_AGENT_IDLE_TIMEOUT=300
# CREWCRAFT_AGENT_HEARTBEAT_INTERVAL=15

# ── Collaboration Supervision ─────────────────────────────────────
# CREWCRAFT_COLLAB_MAX_ROUNDS=10
# CREWCRAFT_COLLAB_MAX_DEPTH=3
# CREWCRAFT_COLLAB_TIMEOUT=60

# ── Logging ───────────────────────────────────────────────────────
# CREWCRAFT_LOG_LEVEL=INFO
